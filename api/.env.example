# --- BACKEND DOMAIN MASTER ---
API_PORT=3001
NODE_ENV=development
PORT=3001
SSL_MODE=false

# Infrastructure (Local access)
DB_HOST=localhost
MONGO_USER=mongodb
MONGO_PASSWORD=root
MONGO_DB=chat
MONGO_URI=mongodb://${MONGO_USER}:${MONGO_PASSWORD}@${DB_HOST}:27017/${MONGO_DB}

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Security
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Logic
RATE_LIMIT_POINTS=120
RATE_LIMIT_DURATION=60
WS_MAX_MESSAGE_SIZE=1000000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000
