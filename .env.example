# --- INFRASTRUCTURE CONTROL (DOCKER) ---
NODE_ENV=development
SSL_MODE=false
API_PORT=3001
WEB_PORT=3000
DOMAIN=localhost
WEB_PUBLIC_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# --- BACKEND (API) ---
PORT=3001
DB_HOST=mongodb
MONGO_USER=mongodb
MONGO_PASSWORD=root
MONGO_DB=chat
MONGO_URI=mongodb://${MONGO_USER}:${MONGO_PASSWORD}@${DB_HOST}:27017/${MONGO_DB}
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
RATE_LIMIT_POINTS=120
RATE_LIMIT_DURATION=60
WS_MAX_MESSAGE_SIZE=1000000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000

# --- FRONTEND (WEB) ---
PORT_WEB=3000
